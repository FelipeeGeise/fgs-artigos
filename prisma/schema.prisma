generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // --- Dados do Cliente ---
  customerName String
  cpf          String      // Necessário para a Nota Fiscal no Bling
  whatsapp     String
  email        String

  // --- Endereço de Entrega ---
  cep         String
  logradouro  String
  numero      String
  complemento String?     // Adicionado: importante para entregas
  bairro      String
  cidade      String
  uf          String

  // --- Financeiro ---
  total        Float       // Valor final pago pelo cliente
  status       String      @default("PENDENTE") // PENDENTE, PAGO, ENVIADO, ENTREGUE, CANCELADO
  paymentId    String?     // ID de transação do Mercado Pago
  
  // --- Integração Bling (ERP) ---
  blingOrderId String?     @unique // ID do pedido dentro do Bling
  nfeNumber    String?     // Número da Nota Fiscal gerada
  nfeLink      String?     // Link para o PDF da nota, se disponível
  syncStatus   String      @default("AGUARDANDO") // AGUARDANDO, SINCRONIZADO, ERRO

  // --- Logística de Dropshipping ---
  trackingCode String?     // Código que recebes do fornecedor
  shippedAt    DateTime?   // Data em que o produto foi enviado

  items        OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  productId String
  sku       String  // O Bling usa o SKU para identificar qual produto foi vendido
  name      String
  price     Float   // Preço de venda unitário
  quantity  Int

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique // Identificador único comercial (Ex: BBL-001)
  name        String
  description String?
  category    String
  image       String

  // --- Valores de Dropshipping ---
  price       Float    // Preço que o cliente paga
  costPrice   Float    @default(0) // Preço que pagas ao fornecedor
  supplierUrl String?  // Link direto para facilitar a tua compra

  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}